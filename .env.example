# Siege Range Configuration
# Copy this file to .env and fill in real values. .env is gitignored.
#
# Anything marked REQUIRED has no default — boot fails fast (CLAUDE.md
# §3.2 / §8.2) if it isn't set.

# --- Application environment ---
# One of: development | test | staging | production
# In production ALLOWED_ORIGINS, FRONTEND_URL, MAIL_FROM, and SMTP_HOST
# are all required (validated at boot via Pydantic settings).
APP_ENV=development

# --- Web Server ---
SIEGE_PORT=3000
TZ=UTC

# --- PostgreSQL ---
POSTGRES_USER=siege
POSTGRES_PASSWORD=siege_secret
POSTGRES_DB=siege_range

# --- Application secrets (REQUIRED — no placeholder defaults) ---
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# 32+ characters required, must not match any known placeholder string.
SECRET_KEY=

# --- Admin Account ---
# ADMIN_PASSWORD is REQUIRED. 12+ characters, not "Admin123!@#" or any
# other obvious placeholder. The bootstrap admin is created on first
# boot from these values.
ADMIN_EMAIL=admin@siege.local
ADMIN_PASSWORD=

# --- CORS allowlist ---
# Comma-separated origins. Empty + APP_ENV=development falls back to
# http://localhost:3000 and http://localhost:5173. Empty +
# APP_ENV=production fails the boot.
# Example: ALLOWED_ORIGINS=https://siege.example.com,https://adminREDACTED.example.com
ALLOWED_ORIGINS=

# --- Container Lifecycle ---
# Max seconds a challenge container can run (default 2 hours)
CONTAINER_TIMEOUT=7200

# --- Orchestrator Resource Limits ---
ORCHESTRATOR_CPUS=4.0
ORCHESTRATOR_MEMORY=8g

# --- VPN (WireGuard) ---
VPN_SERVER_URL=auto
VPN_PORT=51820
VPN_PEERS=10

# --- Egress proxy hot-reload ---
# Sprint 4 / 5: the api process renders the active per-instance
# allowlist to this path; the egress-proxy container reads it on
# SIGHUP. docker-compose.yml mounts the same shared volume on both.
EGRESS_FILTER_PATH=/srv/egress/egress-allowlist.conf

# --- SMTP (password reset, email verification, future transactional) ---
# Sprints 6 / 9. Optional in dev/test (falls back to printing emails
# to stderr as JSON for inspection in `docker compose logs api`).
# REQUIRED in production along with MAIL_FROM + FRONTEND_URL — boot
# rejects production with any of these missing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=
# Public URL of the frontend; reset / verify links embed this.
FRONTEND_URL=

# --- Email-verification gate (Sprint 10 Phase C) ---
# When true, login returns 403 for users with email_verified=False.
# Default off so existing users aren't locked out the moment SMTP is
# turned on. Flip on once everyone has verified.
REQUIRE_EMAIL_VERIFIED=false

# --- Password reset token TTL (Sprint 6) ---
PASSWORD_RESET_TTL_MINUTES=60

# --- Automated DB backups (Sprint 12 Phase A) ---
# Scheduler runs pg_dump nightly at 02:30 UTC, writes to BACKUP_DIR,
# prunes files older than BACKUP_RETENTION_DAYS. Set BACKUP_DIR to an
# empty string to opt out (e.g. when an external system handles
# backups).
BACKUP_DIR=/var/lib/siege-range/backups
BACKUP_RETENTION_DAYS=30

# --- OpenTelemetry tracing (Sprint 11 Phase C) ---
# Opt-in. When set, the api process ships spans for inbound HTTP,
# SQLAlchemy, and outbound httpx calls to the configured collector.
# Leave blank to disable (no overhead).
# Example: OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=siege-range

# --- Outbound webhooks (Sprint 8) ---
# Slack / Teams URLs were removed in Phase 12 slice 9. Outbound
# webhooks are now managed via the v1 admin surface
# (POST /api/v1/webhooks). No env config needed.
