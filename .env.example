# Siege Range Configuration
# Copy this file to .env and fill in real values. .env is gitignored.

# --- Application environment ---
# One of: development | test | staging | production
# In production ALLOWED_ORIGINS is required and must list real origins.
APP_ENV=development

# --- Web Server ---
SIEGE_PORT=3000
TZ=UTC

# --- PostgreSQL ---
POSTGRES_USER=siege
POSTGRES_PASSWORD=siege_secret
POSTGRES_DB=siege_range

# --- Application secrets (REQUIRED — no placeholder defaults) ---
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# 32+ characters required, must not match any known placeholder string.
SECRET_KEY=

# --- Admin Account ---
# ADMIN_PASSWORD is REQUIRED. 12+ characters, not "Admin123!@#" or any
# other obvious placeholder.
ADMIN_EMAIL=admin@siege.local
ADMIN_PASSWORD=

# --- CORS allowlist ---
# Comma-separated origins. Empty + APP_ENV=development falls back to
# http://localhost:3000 and http://localhost:5173. Empty +
# APP_ENV=production fails the boot.
# Example: ALLOWED_ORIGINS=https://siege.example.com,https://adminREDACTED.example.com
ALLOWED_ORIGINS=

# --- Container Lifecycle ---
# Max seconds a challenge container can run (default 2 hours)
CONTAINER_TIMEOUT=7200

# --- Orchestrator Resource Limits ---
ORCHESTRATOR_CPUS=4.0
ORCHESTRATOR_MEMORY=8g

# --- VPN (WireGuard) ---
VPN_SERVER_URL=auto
VPN_PORT=51820
VPN_PEERS=10

# --- Webhooks (optional) ---
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
