# Environment
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
.venv-test/
venv/

# Node
node_modules/
frontend/node_modules/
frontend/dist/

# Phase 12 (slice 20) — Playwright outputs.
frontend/test-results/
frontend/playwright-report/
frontend/.playwright/

# Docker
dind_data/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Backups
backups/

# Certs
nginx/certs/

# Logs (runtime debug spew, not part of source)
*.log
# … but challenge log corpora ARE source. They're hand-authored
# synthetic data the hunter must analyse; without them the
# challenge doesn't work.
!challenges/**/logs/*.log
# Example challenge artefacts (training material) — keep them tracked
# so the loader integration tests can validate against the manifest
# digests committed alongside.
!examples/challenges/**/artifacts/*.log
.memory-backups/
.env.local
.env.*.local
.coverage

# Per-deploy secrets — flags, answers, and other operator-only blobs.
# Loaded at build / seed time by the matching scripts under scripts/.
secrets/

# Per-challenge sealed sidecars staged by scripts/stage-answers.sh
# immediately before docker build. Never committed.
challenges/*/.answers.json
challenges/*/.flag.txt
